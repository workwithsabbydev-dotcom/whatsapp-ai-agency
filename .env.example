# Server
PORT=8000
ENVIRONMENT=development

# Database (Neon PostgreSQL)
# Example: postgresql+asyncpg://user:password@ep-withered-leaf-1234.us-east-2.aws.neon.tech/neondb
DATABASE_URL=postgresql+asyncpg://username:password@hostname/dbname

# Agency Gemini API Key (Master Key)
GEMINI_API_KEY=your_google_gemini_api_key

# Google Service Account JSON (can be a filepath or the literal JSON string)
GOOGLE_CREDENTIALS_JSON=path/to/service-account.json

# Webhook Verification Token (set in Meta Developer Console)
WEBHOOK_VERIFY_TOKEN=your_secure_verify_token_123

# Meta App Secret (from Meta Developer Dashboard > App Settings > Basic)
# Required for X-Hub-Signature-256 webhook validation in production
META_APP_SECRET=your_meta_app_secret

# Admin API Key (For internal management endpoints)
ADMIN_API_KEY=super_secret_admin_key_for_onboarding

# Encryption Key for Tenant Tokens (Generate with fernet)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_generated_fernet_key
